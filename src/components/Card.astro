---
import type { CollectionEntry } from "astro:content";
import { DAILY_PATH } from "@/content.config";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & (CollectionEntry<"blog"> | CollectionEntry<"daily">);

const { variant: Heading = "h2", id, data, filePath, body, collection } =
  Astro.props;

const title = data.title;
const datetimeProps = {
  pubDatetime: data.pubDatetime,
  modDatetime: data.modDatetime,
  timezone: data.timezone,
};
const href =
  collection === "daily"
    ? getPath(id, filePath, {
        basePath: "/daily",
        contentPath: DAILY_PATH,
        slug: data.slug,
      })
    : getPath(id, filePath, { slug: data.slug });

const preview = (body ?? "")
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
  .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
  .replace(/^#{1,6}\s+/gm, "")
  .replace(/[>*_~`-]/g, " ")
  .replace(/\s+/g, " ")
  .trim();

const description =
  "description" in data
    ? data.description
    : preview.length > 120
      ? `${preview.slice(0, 120).trimEnd()}...`
      : preview || "An inspire without more description.";
---

<li class="my-6">
  <a
    href={href}
    class:list={[
      "pb-1",
      "inline-block text-lg font-medium text-accent",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>
  </a>
  <Datetime class:list={["pb-1"]} {...datetimeProps} />
  <p>{description}</p>
</li>
