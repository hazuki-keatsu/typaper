---
import "aplayer/dist/APlayer.min.css";
import "@/styles/aplayer.css";
---

<div id="aplayer-container" transition:persist="aplayer"></div>

<script>
  // @ts-ignore
  import APlayer from "aplayer";

  // 使用本地 Astro API 获取歌单数据
  document.addEventListener("astro:page-load", async () => {
    const container = document.getElementById("aplayer-container");
    if (!container || container.hasAttribute("data-aplayer-initialized")) return;

    container.setAttribute("data-aplayer-initialized", "true");

    try {
      // 调用本地 API 获取歌单数据
      const res = await fetch("/api/music");
      if (!res.ok) {
        throw new Error(`获取歌单失败: ${res.status}`);
      }

      const audio = await res.json();

      if (!Array.isArray(audio) || audio.length === 0) {
        throw new Error("歌单为空或格式错误");
      }

      const ap = new APlayer({
        container: container,
        fixed: true,
        lrcType: 0,
        theme: "var(--accent)",
        audio: audio,
      });

      // 默认隐藏悬浮歌词
      ap.lrc.hide();

      console.log("[APlayer] 初始化成功，共", audio.length, "首歌曲");
    } catch (e) {
      console.error("APlayer 初始化失败", e);
    }
  });
</script>
